{
  "name": "vue3-ts-template",
  "version": "1.2.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "npm run dev",
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:test": "vite build --mode test",
    "preview": "npm run build && vite preview",
    "preview:dist": "vite preview",
    "lint": "eslint ./src --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "less": "^4.6.4",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  },
  "engines": {
    "node": ">=20.20.0",
    "npm": ">=10.8.0"
  },
  "repository": {
    "url": "https://github.com/yuanlee301415/Vue3-TS-Template"
  }
}
